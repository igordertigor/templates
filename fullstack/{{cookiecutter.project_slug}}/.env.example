# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB={{ cookiecutter.project_slug }}

{% if cookiecutter.shared_db == "n" %}
# Zitadel PostgreSQL (separate instance)
ZITADEL_POSTGRES_USER=zitadel
ZITADEL_POSTGRES_PASSWORD=changeme
{% endif %}

# Zitadel
# Generate with: openssl rand -base64 32 | head -c 32
ZITADEL_MASTERKEY=changeme_must_be_32_chars_exactly!
ZITADEL_CLIENT_ID=  # Fill in after Zitadel setup (see README)

{% if cookiecutter.add_arq == "y" %}
# Redis
REDIS_URL=redis://redis:6379
{% endif %}

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
