# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB={{ cookiecutter.project_slug }}

{% if cookiecutter.shared_db == "n" %}
# Authentik PostgreSQL (separate instance)
AUTHENTIK_POSTGRES_USER=authentik
AUTHENTIK_POSTGRES_PASSWORD=changeme
{% endif %}

# -----------------------------
# Authentik Configuration
# -----------------------------

# Security - Secret key (required)
# Generate with: openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=changeme_use_openssl_rand_base64_60

# Version pinning
AUTHENTIK_TAG=2026.2.2
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server

# Ports (for local development)
AUTHENTIK_PORT_HTTP=8080
AUTHENTIK_PORT_HTTPS=8443

# Error reporting (disabled by default for privacy)
AUTHENTIK_ERROR_REPORTING__ENABLED=false

# Application configuration (fill in after Authentik setup - see README)
AUTHENTIK_APP_SLUG=
AUTHENTIK_CLIENT_ID=

{% if cookiecutter.add_arq == "y" %}
# Redis
REDIS_URL=redis://redis:6379
{% endif %}

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
